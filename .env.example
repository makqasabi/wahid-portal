# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=wahid_portal
DATABASE_URL=postgresql://postgres:CHANGE_ME_strong_random_password@db:5432/wahid_portal?schema=public

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# Require 2FA for ENTITY_ADMIN/SUPER_ADMIN before they can sign in.
# Enrol admins in 2FA FIRST, then set true (avoids lockout).
ENFORCE_ADMIN_MFA=false

# ── Email / SMTP (outbound auto-emails) ──────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@wahid.live

# ── Email / IMAP (inbound — replies become ticket comments) ──
# Enabled automatically once HOST + USER + PASS are set (or force IMAP_ENABLED=true).
# Matches sender to a user and the ticket id (e.g. WAH-0008) in the subject.
IMAP_ENABLED=false
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_TLS=true
IMAP_MAILBOX=INBOX
IMAP_POLL_SECONDS=60

# ── Microsoft / OIDC single sign-on (passwordless + MFA) ─────
# Works with Entra ID or ADFS (OIDC). Point OIDC_ISSUER at the discovery base.
# Entra ID example: https://login.microsoftonline.com/<TENANT_ID>/v2.0
# ADFS example:     https://adfs.yourcompany.com/adfs
# Redirect URI must be registered in the app registration and match exactly:
#   https://wahid.live/api/auth/oidc/callback
# Enabled automatically once ISSUER + CLIENT_ID are set (or force OIDC_ENABLED=true).
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://wahid.live/api/auth/oidc/callback
OIDC_SCOPES=openid profile email
# Reject SSO logins whose email has no existing Wahid account (recommended).
OIDC_ALLOW_SIGNUP=false

# ── WhatsApp Cloud API (auto messages on notification triggers) ─
# Get phone number id + a (system-user) access token from Meta. Enabled
# automatically once both are set (or force WHATSAPP_ENABLED=true).
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v21.0
# Country code (digits only, no +) prepended to local recipient numbers.
WHATSAPP_DEFAULT_COUNTRY_CODE=966
# For business-initiated messages (outside the 24h window) set an approved
# template name; the notification text fills its first {{1}} body placeholder.
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=en

# ── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://wahid.live
UPLOAD_DIR=./uploads

# ── Logging (durable SQLite log store) ───────────────────────
# Every log (HTTP requests, errors, console output, auth attempts, audit
# trail) is written to wahid-logs.db. In Docker this is the /logs volume.
# Leave LOG_DIR unset locally to use <backend>/logs. View logs in-app at
# Admin → System Logs (SUPER_ADMIN), or query the SQLite file directly.
LOG_DIR=/logs
LOG_RETENTION_DAYS=90

# ── Domain (used by deploy script) ──────────────────────────
DOMAIN=wahid.live
CERTBOT_EMAIL=admin@wahid.live
